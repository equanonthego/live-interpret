# 실제 값을 채워 .env.local 로 저장하세요 (.env.local 은 git에 올라가지 않습니다).

# Google AI Studio 유료 키 (Gemini 3.5 Live Translate 사용에 유료 티어 필요)
GEMINI_API_KEY=

# LiveKit Cloud 프로젝트 (https://cloud.livekit.io → Settings → Keys)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# 강의자(방송 시작) 페이지 비밀번호
BROADCAST_PASSWORD=
